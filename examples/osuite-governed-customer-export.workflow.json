        "actionKind": "data_access",
        "riskLevel": 45,
        "systemsTouched": "CRM, Slack, customer data",
        "reversible": false,
        "decisionContext": "This workflow touches customer-related account data and sends a downstream business notification. OSuite should review the action before execution, bind any approval to this specific action, and keep a replayable proof trail.",
        "toolInputJson": "{\n  \"request_id\": \"demo-crm-export-001\",\n  \"requested_by\": \"revenue-ops-demo\",\n  \"business_goal\": \"Prepare a weekly customer-risk summary for the account team\",\n  \"records_requested\": 25,\n  \"systems\": [\"CRM\", \"Slack\", \"customer data\"],\n  \"contains_customer_data\": true,\n  \"destination\": \"internal Slack channel\",\n  \"sample_fields\": [\"company\", \"account_status\", \"renewal_risk\", \"support_notes\"],\n  \"note\": \"Demo data only. No real customer records are used.\"\n}",
        "advanced": {
          "agentId": "n8n-customer-export-demo",
